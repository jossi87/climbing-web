{
  "name": "climbing-web",
  "version": "2.0.0",
  "browserslist": [
    "last 2 versions",
    "not dead",
    "not ie 11",
    "baseline 2020"
  ],
  "description": "Climbing sites used in Norway (climbing and bouldering) - https://brattelinjer.no - https://buldreinfo.com",
  "homepage": "https://github.com/jossi87/climbing-web#readme",
  "license": "GPL-3.0",
  "author": "Jostein Oeygarden <jostein.oygarden@gmail.com> (https://github.com/jossi87)",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/jossi87/climbing-web"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/react-query-devtools": "^5.101.3",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/suncalc": "^1.9.2",
    "@types/svg-path-parser": "^1.1.6",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.4",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "openapi-typescript": "7.13.0",
    "postcss": "^8.5.20",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.22.0",
    "@react-leaflet/core": "^3.0.0",
    "@sentry/react": "^10.67.0",
    "@tanstack/react-query": "^5.101.3",
    "clsx": "^2.1.1",
    "flat": "^6.0.1",
    "heic2any": "^0.0.4",
    "json-url": "^4.0.0",
    "leaflet": "^1.9.4",
    "leaflet.fullscreen": "^5.3.3",
    "leaflet.locatecontrol": "^0.90.0",
    "leaflet.markercluster": "^1.5.3",
    "linkify-react": "^4.3.3",
    "linkifyjs": "^4.3.3",
    "lucide-react": "^1.25.0",
    "pannellum": "^2.5.7",
    "react": "^19.2.7",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.7",
    "react-dropzone": "^19.1.1",
    "react-intersection-observer": "^10.1.0",
    "react-is": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "react-select": "^5.10.2",
    "react-swipeable": "^7.0.2",
    "recharts": "^3.9.2",
    "suncalc": "^2.0.1",
    "svg-path-parser": "^1.1.0",
    "svg-path-properties": "^2.0.2",
    "tailwind-merge": "^3.6.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run validate && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "analyze": "vite build --mode analyze",
    "swagger": "openapi-typescript https://brattelinjer.no/api/v3/api-docs --output src/@types/buldreinfo/swagger.d.ts --export-type",
    "validate": "npm run format:check && npm run lint && npm run type-check",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md}": [
      "prettier --write"
    ]
  }
}
